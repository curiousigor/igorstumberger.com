---
import Base from "../../layouts/Base.astro";
import "../../styles/global.css";
import "../../styles/blog.css";

const postFiles = import.meta.glob(["./*.md", "!./_*.md"], { eager: true });
const posts = Object.values(postFiles)
  .map((post: any) => ({
    url: post.url,
    title: post.frontmatter.title,
    date: post.frontmatter.date,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Base
  title="Blog — Igor Štumberger"
  description="Thoughts on design, development, and building products."
>
  <div class="container">
    <header class="site-header">
      <img src="/images/igor.webp" alt="Igor Štumberger" width="40" height="40" class="site-header-image" />
      <div class="site-header-info">
        <a href="/" class="site-header-name">Igor Štumberger ↗</a>
        <span class="site-header-title">Senior Product Designer</span>
      </div>
    </header>
    <section class="section">
      <span class="section-label">Writing</span>
      <div class="blog-list">
        {
          posts.map((post) => (
            <a href={post.url} class="blog-item">
              <span class="blog-item-title">
                {post.title}
              </span>
              <time class="blog-item-date" datetime={post.date}>
                {new Date(post.date).toLocaleDateString("en-GB", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Base>
