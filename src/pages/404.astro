---
import Base from "../layouts/Base.astro";
import "../styles/global.css";
---

<Base
  title="Page not found — Igor Štumberger"
  description="This page wandered off. Let's get you back."
>
  <div class="container">
    <section class="not-found">
      <span class="not-found-code">404</span>
      <h1 class="not-found-title">Off the map</h1>
      <p class="not-found-text">
        This page doesn't exist — maybe it moved, maybe it never did. Either
        way, sorry for the detour.
      </p>
      <a href="/" class="not-found-link">Back home ↗</a>
    </section>
  </div>
</Base>
