---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const siteUrl = "https://igorstumberger.com";
const socialImage = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/images/meta-img.webp`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={title} />
    <meta property="og:image" content={socialImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <link rel="icon" href="/favicon.ico" />

    <link
      rel="preload"
      href="/fonts/SpaceGrotesk-Variable.ttf"
      as="font"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/SpaceMono-Regular.ttf"
      as="font"
      crossorigin="anonymous"
    />
    <link rel="preload" href="/images/background.webp" as="image" />

    <script
      defer
      data-domain="igorstumberger.com"
      src="https://plausible.hey.si/js/script.hash.outbound-links.js"></script>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Igor Štumberger",
        "url": "https://igorstumberger.com"
      }
    </script>
  </head>
  <body>
    <slot />
    <script>
      console.log(
        "%c\n" +
        "  _   _ _   _    ___  _   _ _ \n" +
        " | | | | | | |  / _ \\| | | | |\n" +
        " | | | | |_| | | | | | |_| | |\n" +
        " | |_| |  _  | | |_| |  _  |_|\n" +
        "  \\___/|_| |_|  \\___/|_| |_(_)\n",
        "color: #ffe11b; font-family: monospace;"
      );
      console.log(
        "%cYou found the secret room. %c\n\n" +
        "I see you like to peek under the hood — me too.\n" +
        "This site is built with Astro, plain CSS, and zero frameworks.\n" +
        "No cookies. Just pixels and care.\n\n" +
        "If you're a designer, developer, or just curious:\n" +
        "→ hi@igorstumberger.com\n" +
        "→ bsky.app/profile/igorstumberger.com\n",
        "color: #ffe11b; font-size: 13px; font-weight: bold;",
        "color: #fff; font-size: 12px; line-height: 1.6;"
      );
    </script>
  </body>
</html>
