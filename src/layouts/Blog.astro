---
import Base from "./Base.astro";
import "../styles/global.css";
import "../styles/blog.css";

interface Props {
  frontmatter: {
    title: string;
    date: string;
    description: string;
    image?: string;
    author?: string;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;
const author = frontmatter.author || "Igor Štumberger";
const tags = frontmatter.tags || [];
const formattedDate = new Date(frontmatter.date).toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base title={`${frontmatter.title} — Igor Štumberger`} description={frontmatter.description} ogImage={frontmatter.image}>
  <div class="container">
    <header class="site-header">
      <img src="/images/igor.webp" alt="Igor Štumberger" width="40" height="40" class="site-header-image" />
      <div class="site-header-info">
        <a href="/" class="site-header-name">Igor Štumberger ↗</a>
        <span class="site-header-title">Design Engineer</span>
      </div>
    </header>
    <article class="blog-post">
      <header class="blog-post-header">
        <a href="/blog" class="blog-back-link">← Writing</a>
        <h1 class="blog-post-title">{frontmatter.title}</h1>
        <div class="blog-post-meta">
          <time class="blog-post-date" datetime={frontmatter.date}>{formattedDate}</time>
          <span class="blog-post-author">by {author}</span>
        </div>
        {tags.length > 0 && (
          <div class="blog-post-tags">
            {tags.map((tag) => (
              <span class="blog-post-tag">{tag}</span>
            ))}
          </div>
        )}
        {frontmatter.image && (
          <img src={frontmatter.image} alt={frontmatter.title} class="blog-post-image" decoding="async" loading="lazy" />
        )}
      </header>
      <div class="blog-post-content">
        <slot />
      </div>
      <footer class="blog-post-footer">
        <p class="blog-post-footer-text">Enjoyed this post? I'd love to hear from you.</p>
        <div class="blog-post-cta-links">
          <a
            href={`mailto:hi@igorstumberger.com?subject=Re: ${frontmatter.title}`}
            class="blog-post-cta"
          >
            Email me ↗
          </a>
          <a
            href="https://bsky.app/profile/igorstumberger.com"
            target="_blank"
            class="blog-post-cta"
          >
            Bluesky ↗
          </a>
        </div>
      </footer>
    </article>
  </div>
</Base>
